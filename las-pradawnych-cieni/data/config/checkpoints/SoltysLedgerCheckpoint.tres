[gd_resource type="Resource" script_class="CheckpointConfig" format=3]

[ext_resource type="Script" path="res://scripts/checkpoints/CheckpointConfig.gd" id="1_checkpoint_config"]
[ext_resource type="Script" path="res://scripts/checkpoints/CheckpointChoiceConfig.gd" id="2_checkpoint_choice"]
[ext_resource type="Texture2D" path="res://assets/ui/checkpoints/soltys_ledger/cp_004_intro.png" id="3_intro"]
[ext_resource type="Texture2D" path="res://assets/ui/checkpoints/soltys_ledger/cp_004_result_a.png" id="4_result_a"]
[ext_resource type="Texture2D" path="res://assets/ui/checkpoints/soltys_ledger/cp_004_result_b.png" id="5_result_b"]

[sub_resource type="Resource" id="CheckpointChoice_1"]
script = ExtResource("2_checkpoint_choice")
text = "Otwórz zapieczętowany rejestr"
result_text = "W księdze są wypłaty za \"patrole\", które nigdy nie wróciły. Każda rubryka kończy się notą: \"sprawę zamknięto decyzją sołtysa\"."
lore_tag = &"ledger_opened"
continue_button_text = "Zamknij księgę"
result_background = ExtResource("4_result_a")

[sub_resource type="Resource" id="CheckpointChoice_2"]
script = ExtResource("2_checkpoint_choice")
text = "Porównaj pieczęcie z dokumentami wypraw"
result_text = "Pieczęć sołtysa pojawia się także na rozkazach wycięcia świętego gaju. To sugeruje, że chaos zaczął się po decyzjach ludzi, nie po przebudzeniu bestii."
lore_tag = &"ledger_seals"
continue_button_text = "Zapamiętaj dowód"
result_background = ExtResource("5_result_b")

[resource]
script = ExtResource("1_checkpoint_config")
checkpoint_id = &"soltys_ledger"
title = "Skrytka Pod Kaplica"
description = "Pod zawaloną kaplicą odnajdujesz suchą skrytkę z księgą rachunkową osady. Ktoś próbował ją spalić, ale kartki ocalały."
lore_tag = &"village_coverup"
background = ExtResource("3_intro")
choices = Array[Resource]([SubResource("CheckpointChoice_1"), SubResource("CheckpointChoice_2")])
